NEXT_PUBLIC_DIRECTUS_URL=https://directus.alattas.de
DIRECTUS_STATIC_TOKEN=your-read-only-token
# Server token for magic links (create/read/update magic_login_links + read users)
DIRECTUS_SERVICE_TOKEN=your-service-token
# Shared secret with Directus extension magic-link-auth (must match Directus server env)
MAGIC_LINK_INTERNAL_SECRET=your-shared-magic-link-secret
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ALADHAN_METHOD=3

# Directus server env (directus.alattas.de) — required for Google login:
# AUTH_GOOGLE_REDIRECT_ALLOW_LIST=https://salat-time.alattas.de/auth/callback/exchange,https://salat-time.alattas.de/auth/callback
# Production server env must include:
# NEXT_PUBLIC_APP_URL=https://salat-time.alattas.de
